# Backend Environment Variables
# Copy this file to .env and fill in your actual values.

# Database Configuration
# Docker (backend/docker/docker-compose.yml): default published port is 15432, not 5432, to avoid clashing with other Postgres containers.
# DATABASE_URL="postgresql://ord_lite_user:ord_lite_pass@127.0.0.1:15432/ord_lite_db?schema=public"
DATABASE_URL="postgresql://your_db_user:your_db_password@your_db_host:15432/your_db_name?schema=public"

# Application Configuration
PORT=3005
SESSION_SECRET="a_strong_random_session_secret_please_change"
# NODE_ENV="development" # or "production"

# ord-litecoin HTTP API (must match the ord instance you actually run)
# Profile "litecoin-mainnet" (default local prod-like): http://127.0.0.1:8081 — see MISSION_CONTROL.md
# Profile "litecoin" (regtest): http://127.0.0.1:8080
ORD_LITECOIN_URL="http://127.0.0.1:8081"

# ord HTTP retries (indexer / reconciler): backoff on ECONNRESET, 503, etc.
# ORD_FETCH_MAX_RETRIES=10
# ORD_FETCH_INITIAL_DELAY_MS=500
# ORD_FETCH_MAX_DELAY_MS=120000

# Indexer (npm run indexer): if the loop still throws after ord retries, pause and restart from DB cursor
# INDEXER_RESTART_BASE_MS=2000
# INDEXER_RESTART_MAX_MS=300000

# Litecoin Core RPC (used by getBlockHeight fallback path; must match your litecoind network)
# Docker "litecoin" regtest: port 19443. Docker "litecoin-mainnet": port 9332.
LITECOIN_RPC_ENABLED=true
LITECOIN_RPC_USER="litecoin"
LITECOIN_RPC_PASS="litecoin"
LITECOIN_RPC_HOST="127.0.0.1"
LITECOIN_RPC_PORT="19443"
LITECOIN_RPC_PROTOCOL="http"
LITECOIN_RPC_TIMEOUT=30000

# Optional: first block height when indexer cursor is 0 (mainnet catch-up)
# INDEXER_START_HEIGHT=

# Reconciler (npm run indexer:reconcile) — backfill / fix Prisma rows from ord
# RECONCILE_HEURISTIC=zeros   # zeros | stale (ordSyncedAt null) | scan (all rows by id)
# RECONCILE_BATCH_SIZE=25
# ORD_REQUEST_DELAY_MS=75
# RECONCILE_MAX_INSCRIPTIONS=0   # 0 = unlimited per run
# RECONCILE_ERROR_BACKOFF_MS=2000
# RECONCILE_RESET_CURSOR=1       # reset id cursor in UpdateProgress for this heuristic

# Inscription Service Configuration
# Example: Base fee for inscriptions, if applicable
# INSCRIPTION_BASE_FEE_SATS=1000

# Other service integrations (e.g., email, external APIs)
# MAILER_HOST=""
# MAILER_PORT=""
# MAILER_USER=""
# MAILER_PASS=""

# Add any other environment variables required by the backend application below
