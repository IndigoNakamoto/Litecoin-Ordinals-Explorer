# Copy to .env next to docker-compose.yml (backend/docker/.env) — do not commit .env
#
# Published Postgres port on your Mac/host (container still uses 5432 internally).
# Default if unset: 15432 — avoids clashing with other Docker DBs on 5432.
# EXPLORER_POSTGRES_PORT=15432
#
# Use the same port in backend/.env DATABASE_URL, e.g. ...@127.0.0.1:15432/ord_lite_db
#
# Litecoin Core (regtest) — must match litecoind service in docker-compose.yml
LITECOIN_RPC_USER=litecoin
LITECOIN_RPC_PASS=litecoin
#
# ord-litecoin publishes HTTP on host port 8080 -> container 80
ORD_LITECOIN_URL=http://127.0.0.1:8080
#
# Git ref for docker compose build of ynohtna92/ord-litecoin (tag, branch, or commit).
# ORD_LITECOIN_GIT_REF=0.20.1-litecoin
#
# Keep ord RPC concurrency conservative on Docker Desktop / macOS.
# ORD_LITECOIN_RPC_LIMIT=2
#
# Profile litecoin-mainnet — host ports (avoid clashes with another full node)
# LITECOIN_MAINNET_RPC_PORT=9332
# LITECOIN_MAINNET_P2P_PORT=9333
# LITECOIN_MAINNET_ORD_HTTP_PORT=8081
