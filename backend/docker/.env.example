# Copy to .env next to docker-compose.yml (backend/docker/.env) — do not commit .env
#
# Litecoin Core (regtest) — must match litecoind service in docker-compose.yml
LITECOIN_RPC_USER=litecoin
LITECOIN_RPC_PASS=litecoin
#
# ord-litecoin publishes HTTP on host port 8080 -> container 80
ORD_LITECOIN_URL=http://127.0.0.1:8080
