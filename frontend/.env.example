# Frontend Environment Variables
# Copy this file to .env.local (Next.js convention) and fill in your actual values.

# URL of the backend API
NEXT_PUBLIC_API_URL="http://localhost:3005/api" # Must match backend PORT in backend/.env

# URL of the ord-litecoin HTTP server used for inscription content previews
NEXT_PUBLIC_ORD_BASE_URL="http://127.0.0.1:8081"

# Example: Public key for a third-party service (e.g., Stripe, Google Analytics)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# NEXT_PUBLIC_GA_TRACKING_ID=""

# Add any other environment variables required by the frontend application below
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Other variables (without the prefix) are only available in Node.js environments (e.g., API routes, getServerSideProps).
